# -----------------------------------------------------------------------
# APEX Backend — Environment Variables
#
# Copy this file to .env and fill in your own values where indicated.
# The hosted version at https://apexsimulator.org is already configured.
# These values are only needed for local development.
# -----------------------------------------------------------------------

# --- Database (shared Supabase project — safe to use for local testing) ---
database_url=postgresql+psycopg2://postgres.flbzefzyxgxpmorwlcxp:MedllmCapstone2526@aws-1-us-east-2.pooler.supabase.com:5432/postgres?sslmode=require

# --- LLM API keys (REQUIRED — provide your own keys) ---
# At least one of openai_api_key or gemini_api_key must be set.
openai_api_key=your-openai-api-key-here
gemini_api_key=your-gemini-api-key-here

# --- Supabase storage for assistant audio ---
supabase_url=https://flbzefzyxgxpmorwlcxp.supabase.co
supabase_service_role_key=your-supabase-service-role-key-here
supabase_storage_bucket="patient audio files"
assistant_audio_ttl_seconds=604800
assistant_audio_signed_url_ttl_seconds=3600

# --- Supabase Auth JWT verification ---
# Found in Supabase dashboard: Project Settings > API > JWT Settings > Legacy JWT Secret
SUPABASE_JWT_SECRET=your-supabase-jwt-secret-here

# --- Token / session settings ---
SECRET_KEY=dev-super-secret-change-me
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60

# --- Local media/cache paths ---
local_storage_path=./storage
public_base_url=http://localhost:8000

# --- Optional: allow the Vite dev server to call the API ---
# cors_origins=http://localhost:5173
